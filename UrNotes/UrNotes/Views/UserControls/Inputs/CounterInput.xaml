<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="UrNotes.Views.UserControls.Inputs.CounterInput"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:UrNotes.Views.UserControls.Inputs"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- Decrease on the left, current value in the middle, increase on the right -->
    <StackPanel Orientation="Horizontal" Spacing="4">
        <Button x:Name="DecreaseButton"
                Content="-"
                Padding="8 2"
                Background="Transparent"
                BorderThickness="0"
                AutomationProperties.Name="Decrease value"
                Click="DecreaseButton_Click" />
        <TextBlock x:Name="ValueText"
                   VerticalAlignment="Center"
                   FontSize="13"
                   MinWidth="20"
                   TextAlignment="Center" />
        <Button x:Name="IncreaseButton"
                Content="+"
                Padding="8 2"
                Background="Transparent"
                BorderThickness="0"
                AutomationProperties.Name="Increase value"
                Click="IncreaseButton_Click" />
    </StackPanel>
</UserControl>
