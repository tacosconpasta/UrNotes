<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="UrNotes.Views.UserControls.General.ToolBox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:UrNotes.Views.UserControls.General"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ucInputs="using:UrNotes.Views.UserControls.Inputs"
    xmlns:ucButtons="using:UrNotes.Views.UserControls.Buttons"
    mc:Ignorable="d">

    <!-- Bar holding the text formatting tools of a note's editor -->
    <Grid Padding="10 4">
        <StackPanel Orientation="Horizontal"
                    Spacing="8"
                    HorizontalAlignment="Center">
            <ucInputs:CounterInput x:Name="FontSizeCounter" />
            <ucButtons:ColorSquare x:Name="TextColorSquare" />
        </StackPanel>
    </Grid>
</UserControl>
